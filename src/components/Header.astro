---
import { company } from '@data/company';
import { services, installationServices } from '@data/services';

const countertopsService = installationServices.find(s => s.slug === 'countertops');
const productServices = countertopsService
  ? [...services, { name: countertopsService.name, urlPath: countertopsService.urlPath }]
  : services;
---

<header class="bg-brand-navy text-white sticky top-0 z-50 shadow-lg">
  <!-- Main nav -->
  <nav
    x-data="{ open: false, activeMenu: null }"
    class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between"
    aria-label="Main navigation"
  >
    <!-- Logo -->
    <a href="/" class="logo-glare relative flex items-center flex-shrink-0 overflow-hidden rounded-lg" aria-label="All About Floors NW, Home">
      <img
        src="/images/all-about-floors-nw-logo.webp"
        alt="All About Floors NW"
        class="h-16 md:h-20 w-auto max-w-[260px] md:max-w-[320px] object-contain relative z-10"
        width="320"
        height="80"
        loading="eager"
        onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
      />
      <div style="display:none" class="items-center gap-3">
        <div class="bg-brand-gold rounded-lg w-12 h-12 flex items-center justify-center font-heading font-bold text-white text-2xl">A</div>
        <div class="leading-tight">
          <div class="font-heading font-bold text-xl text-white leading-none">All About Floors NW</div>
          <div class="text-brand-gold text-xs font-medium">Vancouver, WA · Est. 1999</div>
        </div>
      </div>
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden lg:flex items-center gap-1 text-sm font-medium">
      <!-- Products dropdown — hover on <li> covers the gap so mouse can reach panel -->
      <li class="relative group" @mouseenter="activeMenu = 'products'" @mouseleave="activeMenu = null">
        <button
          class="flex items-center gap-1 px-3 py-2 rounded hover:text-brand-gold transition-colors"
          aria-haspopup="true"
        >
          Products
          <svg class="w-3.5 h-3.5 transition-transform duration-200" :class="activeMenu === 'products' ? 'rotate-180' : ''" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div
          x-show="activeMenu === 'products'"
          x-transition:enter="transition ease-out duration-150"
          x-transition:enter-start="opacity-0 translate-y-1"
          x-transition:enter-end="opacity-100 translate-y-0"
          x-transition:leave="transition ease-in duration-100"
          x-transition:leave-start="opacity-100 translate-y-0"
          x-transition:leave-end="opacity-0 translate-y-1"
          class="absolute top-full left-0 pt-1 w-52 z-50"
        >
          <div class="bg-white rounded-xl shadow-xl border border-gray-100 py-2">
            {productServices.map(s => (
              <a href={s.urlPath} class="block px-4 py-2.5 text-gray-700 hover:bg-brand-light hover:text-brand-navy transition-colors text-sm">
                {s.name}
              </a>
            ))}
          </div>
        </div>
      </li>

      <!-- Services dropdown -->
      <li class="relative group" @mouseenter="activeMenu = 'services'" @mouseleave="activeMenu = null">
        <button
          class="flex items-center gap-1 px-3 py-2 rounded hover:text-brand-gold transition-colors"
          aria-haspopup="true"
        >
          Services
          <svg class="w-3.5 h-3.5 transition-transform duration-200" :class="activeMenu === 'services' ? 'rotate-180' : ''" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div
          x-show="activeMenu === 'services'"
          x-transition:enter="transition ease-out duration-150"
          x-transition:enter-start="opacity-0 translate-y-1"
          x-transition:enter-end="opacity-100 translate-y-0"
          x-transition:leave="transition ease-in duration-100"
          x-transition:leave-start="opacity-100 translate-y-0"
          x-transition:leave-end="opacity-0 translate-y-1"
          class="absolute top-full left-0 pt-1 w-52 z-50"
        >
          <div class="bg-white rounded-xl shadow-xl border border-gray-100 py-2">
            {installationServices.map(s => (
              <a href={s.urlPath} class="block px-4 py-2.5 text-gray-700 hover:bg-brand-light hover:text-brand-navy transition-colors text-sm">
                {s.name}
              </a>
            ))}
          </div>
        </div>
      </li>

      <li><a href="/in-store-visit/" class="px-3 py-2 rounded hover:text-brand-gold transition-colors">In-Store Visits</a></li>
      <li><a href="/service-areas/" class="px-3 py-2 rounded hover:text-brand-gold transition-colors">Areas We Serve</a></li>
      <li><a href="/financing/" class="px-3 py-2 rounded hover:text-brand-gold transition-colors">Financing</a></li>
      <li><a href="/about/" class="px-3 py-2 rounded hover:text-brand-gold transition-colors">About</a></li>
    </ul>

    <!-- CTA + mobile toggle -->
    <div class="flex items-center gap-4">
      <a href="/free-estimate/" class="hidden md:inline-flex btn-primary text-sm py-2 px-5">
        Free Estimate
      </a>

      <!-- Mobile hamburger -->
      <button
        @click="open = !open"
        class="lg:hidden flex flex-col gap-1.5 w-8 h-8 justify-center items-center"
        aria-label="Toggle menu"
        :aria-expanded="open"
      >
        <span class="w-6 h-0.5 bg-white transition-all duration-200" :class="open ? 'rotate-45 translate-y-2' : ''"></span>
        <span class="w-6 h-0.5 bg-white transition-all duration-200" :class="open ? 'opacity-0' : ''"></span>
        <span class="w-6 h-0.5 bg-white transition-all duration-200" :class="open ? '-rotate-45 -translate-y-2' : ''"></span>
      </button>
    </div>

    <!-- Mobile menu -->
    <div
      x-show="open"
      x-transition:enter="transition ease-out duration-200"
      x-transition:enter-start="opacity-0 -translate-y-2"
      x-transition:enter-end="opacity-100 translate-y-0"
      class="absolute top-full left-0 right-0 bg-brand-dark border-t border-white/10 py-4 px-4 lg:hidden z-50 shadow-xl"
    >
      <div class="space-y-1 text-sm">
        <div class="font-semibold text-brand-gold px-3 py-1">Products</div>
        {productServices.map(s => (
          <a href={s.urlPath} class="block px-3 py-2 text-gray-300 hover:text-white hover:bg-white/10 rounded transition-colors">
            {s.name}
          </a>
        ))}
        <div class="font-semibold text-brand-gold px-3 py-1 mt-3">Services</div>
        {installationServices.map(s => (
          <a href={s.urlPath} class="block px-3 py-2 text-gray-300 hover:text-white hover:bg-white/10 rounded transition-colors">
            {s.name}
          </a>
        ))}
        <div class="mt-3 space-y-1">
          <a href="/in-store-visit/" class="block px-3 py-2 text-gray-300 hover:text-white hover:bg-white/10 rounded">In-Store Visits</a>
          <a href="/service-areas/" class="block px-3 py-2 text-gray-300 hover:text-white hover:bg-white/10 rounded">Areas We Serve</a>
          <a href="/financing/" class="block px-3 py-2 text-gray-300 hover:text-white hover:bg-white/10 rounded">Financing</a>
          <a href="/about/" class="block px-3 py-2 text-gray-300 hover:text-white hover:bg-white/10 rounded">About</a>
        </div>
        <div class="pt-3 flex gap-3">
          <a href="/free-estimate/" class="btn-primary text-sm py-2 flex-1 text-center">Free Estimate</a>
          <a href={company.cta.phone} class="btn-outline-white text-sm py-2 flex-1 text-center">{company.phone}</a>
        </div>
      </div>
    </div>
  </nav>
</header>
