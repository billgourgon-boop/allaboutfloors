---
import BaseLayout from '@layouts/BaseLayout.astro';
import { company } from '@data/company';
import { reviews } from '@data/reviews';

// Pull 3 short reviews for the calendar page (keep it tight).
const featuredReviews = reviews
  .filter(r => r.text.length < 220)
  .slice(0, 3);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Book Your Free In-Home Flooring Estimate Appointment',
  url: 'https://www.allaboutfloorsnw.com/book-in-home/',
  description: 'Pick a time for your free in-home flooring estimate from All About Floors NW in Vancouver, WA.',
};

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', { year: 'numeric', month: 'long' });
}
---

<BaseLayout
  title="Pick Your Appointment Time | All About Floors NW"
  description="Pick a time for your free in-home flooring estimate. Same-week appointments available across Clark County, WA."
  schema={schema}
  bare={true}
  noIndex={true}
>
  <!-- Meta Pixel Code (in <head>) — Schedule fires later on booking confirmation -->
  <Fragment slot="head">
    <script is:inline>
      !function(f,b,e,v,n,t,s)
      {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)}(window, document,'script',
      'https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', '1975197519985839');
      fbq('track', 'PageView');
    </script>
    <noscript><img height="1" width="1" style="display:none"
      src="https://www.facebook.com/tr?id=1975197519985839&ev=PageView&noscript=1"
    /></noscript>
  </Fragment>

  <!-- Flashy red marquee with limited-time offer -->
  <div class="bg-red-600 text-white overflow-hidden border-y border-red-800/40 shadow-md relative">
    <div class="marquee-track flex whitespace-nowrap py-2.5 text-sm font-semibold tracking-wide">
      {Array.from({ length: 2 }).map(() => (
        <div class="flex shrink-0 items-center gap-8 pr-8">
          <span class="flex items-center gap-2"><span class="inline-block w-1.5 h-1.5 bg-yellow-300 rounded-full animate-pulse"></span> ⏳ Limited time offer</span>
          <span class="flex items-center gap-2"><span class="inline-block w-1.5 h-1.5 bg-yellow-300 rounded-full animate-pulse"></span> Only 10 spots available this week</span>
          <span class="flex items-center gap-2"><span class="inline-block w-1.5 h-1.5 bg-yellow-300 rounded-full animate-pulse"></span> Free in-home estimate</span>
          <span class="flex items-center gap-2"><span class="inline-block w-1.5 h-1.5 bg-yellow-300 rounded-full animate-pulse"></span> ⭐ 5.0 stars · 100+ Google reviews</span>
          <span class="flex items-center gap-2"><span class="inline-block w-1.5 h-1.5 bg-yellow-300 rounded-full animate-pulse"></span> Family-owned since 1999</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Minimal brand bar (locked) -->
  <div class="bg-brand-navy py-3 border-b border-white/5">
    <div class="max-w-7xl mx-auto px-4 flex items-center justify-center">
      <img
        src="/images/all-about-floors-nw-logo.webp"
        alt="All About Floors NW"
        class="h-10 w-auto max-w-[200px] object-contain"
        width="200"
        height="40"
        loading="eager"
      />
    </div>
  </div>

  <!-- Hero + calendar -->
  <section class="bg-brand-navy text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 20% 30%, #C8A55B 0%, transparent 50%), radial-gradient(circle at 80% 70%, #C8A55B 0%, transparent 50%);"></div>
    <div class="max-w-5xl mx-auto px-4 py-12 md:py-16 relative z-10 text-center">
      <!-- Spots remaining pill -->
      <span class="inline-flex items-center gap-2 bg-red-600/20 border border-red-500/40 text-red-100 text-xs md:text-sm font-semibold uppercase tracking-widest px-4 py-1.5 rounded-full mb-5">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-red-500"></span>
        </span>
        Only 10 Spots Available This Week
      </span>

      <h1 class="font-heading font-bold text-4xl md:text-5xl lg:text-6xl leading-tight mb-4">
        Pick a Time That Works for You
      </h1>
      <p class="text-gray-200 text-lg md:text-xl leading-relaxed max-w-2xl mx-auto mb-2">
        Choose a slot below and a member of our Vancouver team will arrive with samples, measure your space, and email you a transparent itemized quote within 24 hours.
      </p>
      <p class="text-brand-gold-light text-sm md:text-base">
        Same-week appointments · Evening slots available · 100% free, no obligation
      </p>
    </div>

    <!-- Calendar embed -->
    <div class="max-w-4xl mx-auto px-4 pb-16 relative z-10">
      <div id="book-calendar" class="rounded-xl overflow-hidden shadow-2xl">
        <!-- Red headline flush with calendar -->
        <div class="bg-red-600 text-white px-5 py-3 text-center">
          <h2 class="font-heading font-bold text-xl md:text-2xl leading-tight">
            Book Your Appointment
          </h2>
          <p class="text-red-50 text-xs md:text-sm mt-0.5 leading-snug">
            Pick a date and time — confirmation sent instantly to your inbox.
          </p>
        </div>

        <!-- LeadConnector calendar widget -->
        <iframe
          src="https://api.leadconnectorhq.com/widget/booking/CcAYkDN33n4bfYINfcQr"
          style="border:none;width:100%;min-height:780px;display:block;background:white;margin:0;overflow:hidden;"
          scrolling="no"
          id="CcAYkDN33n4bfYINfcQr_1778343110811"
          title="Free Flooring Estimate Appointment Calendar"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- Mini review strip below calendar -->
  <section class="bg-brand-light py-14">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-8">
        <div class="inline-flex items-center gap-2 mb-2">
          <div class="flex gap-0.5 text-amber-400 text-lg">★★★★★</div>
          <span class="font-heading font-bold text-brand-navy">5.0</span>
        </div>
        <h2 class="font-heading font-bold text-2xl md:text-3xl text-brand-navy">
          You're in good hands.
        </h2>
        <p class="text-gray-600 text-sm mt-1">From your Clark County neighbors.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {featuredReviews.map(review => (
          <div class="bg-white rounded-xl p-5 shadow-sm flex flex-col">
            <div class="flex items-start gap-3 mb-3">
              <div class="w-9 h-9 rounded-full bg-brand-navy text-white font-bold flex items-center justify-center flex-shrink-0 text-sm">
                {review.name[0]}
              </div>
              <div class="flex-1 min-w-0">
                <div class="font-semibold text-brand-navy text-sm">{review.name}</div>
                <div class="text-xs text-gray-500">{review.location} · {formatDate(review.date)}</div>
              </div>
              <svg class="w-4 h-4 flex-shrink-0 mt-1" viewBox="0 0 48 48" aria-label="Google">
                <path fill="#FFC107" d="M43.611 20.083H42V20H24v8h11.303c-1.649 4.657-6.08 8-11.303 8-6.627 0-12-5.373-12-12s5.373-12 12-12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 12.955 4 4 12.955 4 24s8.955 20 20 20 20-8.955 20-20c0-1.341-.138-2.65-.389-3.917z"/>
                <path fill="#FF3D00" d="M6.306 14.691l6.571 4.819C14.655 15.108 18.961 12 24 12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 16.318 4 9.656 8.337 6.306 14.691z"/>
                <path fill="#4CAF50" d="M24 44c5.166 0 9.86-1.977 13.409-5.192l-6.19-5.238A11.91 11.91 0 0124 36c-5.202 0-9.619-3.317-11.283-7.946l-6.522 5.025C9.505 39.556 16.227 44 24 44z"/>
                <path fill="#1976D2" d="M43.611 20.083H42V20H24v8h11.303a12.04 12.04 0 01-4.087 5.571l.003-.002 6.19 5.238C36.971 39.205 44 34 44 24c0-1.341-.138-2.65-.389-3.917z"/>
              </svg>
            </div>
            <div class="flex gap-0.5 text-amber-400 text-xs mb-2">{'★'.repeat(review.rating)}</div>
            <p class="text-gray-700 text-sm leading-relaxed italic flex-1">"{review.text}"</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Trust strip -->
  <div class="bg-brand-dark text-gray-300 py-5 border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-xs md:text-sm">
      <span class="flex items-center gap-1.5"><svg class="w-4 h-4 text-brand-gold" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg> WA Licensed &amp; Insured</span>
      <span class="flex items-center gap-1.5"><svg class="w-4 h-4 text-brand-gold" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg> Family-Owned Since 1999</span>
      <span class="flex items-center gap-1.5"><svg class="w-4 h-4 text-brand-gold" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg> No Subcontractors</span>
    </div>
  </div>

  <!-- Thank-you overlay (shown after successful booking) -->
  <div
    id="booking-thank-you"
    class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/70 backdrop-blur-sm p-4"
    role="dialog"
    aria-modal="true"
    aria-labelledby="thank-you-heading"
  >
    <div class="bg-white rounded-2xl shadow-2xl max-w-md w-full p-8 text-center">
      <div class="mx-auto w-16 h-16 rounded-full bg-green-100 flex items-center justify-center mb-5">
        <svg class="w-9 h-9 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
        </svg>
      </div>
      <h2 id="thank-you-heading" class="font-heading font-bold text-2xl md:text-3xl text-brand-navy mb-3">
        Thanks for booking!
      </h2>
      <p class="text-gray-600 leading-relaxed mb-6">
        Your free in-home estimate is on the calendar. We've sent a confirmation to your inbox — a member of our Vancouver team will see you soon.
      </p>
      <a href="/" class="btn-primary w-full justify-center">
        Back to Website
      </a>
    </div>
  </div>

  <!-- LeadConnector embed script (handles auto-resize) -->
  <script src="https://link.msgsndr.com/js/form_embed.js" is:inline></script>

  <!-- Show thank-you overlay + fire Meta Pixel Schedule event on successful booking -->
  <script is:inline>
    (function () {
      const overlay = document.getElementById('booking-thank-you');
      if (!overlay) return;

      const params = new URLSearchParams(window.location.search);
      const DEBUG = params.get('debug') === '1';
      function dlog() {
        if (!DEBUG) return;
        try { console.log.apply(console, ['[booking-debug]'].concat([].slice.call(arguments))); } catch (_) {}
      }

      function show(reason) {
        // Window-scoped dedup — multiple script instances on the same page
        if (window.__aafnwScheduleFired) return;
        // localStorage-scoped dedup — survives page reloads within 60s window
        try {
          const last = parseInt(localStorage.getItem('aafnwScheduleAt') || '0', 10);
          if (last && (Date.now() - last) < 60000) {
            dlog('Schedule recently fired (localStorage), skipping. reason was:', reason);
            window.__aafnwScheduleFired = true;
            // still show the overlay so the user sees confirmation
            overlay.classList.remove('hidden');
            overlay.classList.add('flex');
            document.body.style.overflow = 'hidden';
            return;
          }
        } catch (_) {}
        window.__aafnwScheduleFired = true;
        dlog('show() reason:', reason);
        overlay.classList.remove('hidden');
        overlay.classList.add('flex');
        document.body.style.overflow = 'hidden';
        window.scrollTo({ top: 0, behavior: 'smooth' });
        if (typeof window.fbq === 'function') {
          const eventID = 'aafnw-schedule-' + Date.now() + '-' + Math.random().toString(36).slice(2, 8);
          window.fbq('track', 'Schedule', {}, { eventID: eventID });
          try { localStorage.setItem('aafnwScheduleAt', Date.now().toString()); } catch (_) {}
          dlog('fbq Schedule fired, eventID=', eventID);
        } else {
          dlog('fbq not loaded — Schedule NOT fired');
        }
      }

      // Fallback trigger: if GHL is configured to redirect to ?booked=1
      // after submission, show the overlay immediately on page load.
      if (params.get('booked') === '1' || params.get('thank-you') === '1') {
        show('url-param');
      }

      function flatten(obj, depth) {
        if (depth > 4) return '';
        if (obj == null) return '';
        if (typeof obj === 'string') return obj;
        if (typeof obj === 'number' || typeof obj === 'boolean') return String(obj);
        if (typeof obj !== 'object') return '';
        try {
          return Object.keys(obj).map(k => k + ':' + flatten(obj[k], depth + 1)).join(' ');
        } catch (_) {
          return '';
        }
      }

      function isBookingSuccess(payload) {
        if (!payload) return false;
        const flat = (typeof payload === 'string' ? payload : flatten(payload, 0)).toLowerCase();
        if (!flat) return false;
        if (flat.includes('error') || flat.includes('failed')) return false;
        // Reject pure resize/height chatter that has no success-y keyword
        const successWords = ['success','booked','completed','confirmed','submitted','scheduled','thank','appointment','booking'];
        const isResizeLike = (flat.includes('resize') || flat.includes('height')) && !successWords.some(w => flat.includes(w));
        if (isResizeLike) return false;
        const directHits = [
          'appointment-booked','appointment-confirmed','appointment-completed','appointment-scheduled',
          'booking-success','booking-confirmed','booking-completed','booking-scheduled',
          'form-submission-success','survey-submission-success','submission-completed',
          'thank-you','thankyou','thank_you',
        ];
        for (let i = 0; i < directHits.length; i++) if (flat.includes(directHits[i])) return true;
        if ((flat.includes('appointment') || flat.includes('booking') || flat.includes('schedule')) &&
            (flat.includes('success') || flat.includes('booked') ||
             flat.includes('completed') || flat.includes('confirmed') ||
             flat.includes('scheduled'))) {
          return true;
        }
        if (typeof payload === 'object') {
          if (payload.appointmentId || payload.bookingId || payload.submissionId) return true;
          if (payload.data && (payload.data.appointmentId || payload.data.bookingId || payload.data.submissionId)) return true;
          if (payload.params && (payload.params.appointmentId || payload.params.bookingId)) return true;
        }
        return false;
      }

      window.addEventListener('message', function (e) {
        const okOrigin = typeof e.origin === 'string' && (
          e.origin.includes('leadconnectorhq.com') ||
          e.origin.includes('msgsndr.com') ||
          e.origin.includes('gohighlevel.com')
        );
        if (!okOrigin) return;
        dlog('postMessage from', e.origin, e.data);
        if (isBookingSuccess(e.data)) {
          const tag = typeof e.data === 'string' ? e.data : JSON.stringify(e.data).slice(0, 200);
          show('postMessage:' + tag);
        }
      });
    })();
  </script>
</BaseLayout>
