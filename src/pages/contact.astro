---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import GoogleMap from '@components/GoogleMap.astro';
import { company } from '@data/company';
---

<BaseLayout
  title="Contact All About Floors NW | Vancouver, WA Flooring Company"
  description="Contact All About Floors NW in Vancouver, WA. Visit our showroom, call (360) 525-2962, or send us a message. We're open Mon–Sat and happy to answer all your flooring questions."
>
  <div class="bg-brand-navy text-white py-14">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <h1 class="font-heading font-bold text-4xl md:text-5xl mb-4">Contact Us</h1>
      <p class="text-gray-300 text-lg">We're here to help with all your flooring needs in Vancouver, WA.</p>
    </div>
  </div>

  <Breadcrumb items={[{ label: 'Contact' }]} />

  <section class="py-16 bg-brand-light">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Contact form -->
        <div class="bg-white rounded-2xl shadow-lg p-8">
          <h2 class="font-heading font-bold text-brand-navy text-2xl mb-2">Send Us a Message</h2>
          <p class="text-gray-500 text-sm mb-6">We respond to all inquiries within one business day.</p>

          <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="space-y-4">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Name *</label>
                <input type="text" id="name" name="name" required placeholder="Your full name" class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-brand-navy" />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">Phone *</label>
                <input type="tel" id="phone" name="phone" required placeholder="(360) 555-0100" class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-brand-navy" />
              </div>
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email *</label>
              <input type="email" id="email" name="email" required placeholder="you@email.com" class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-brand-navy" />
            </div>
            <div>
              <label for="subject" class="block text-sm font-medium text-gray-700 mb-1">Subject</label>
              <input type="text" id="subject" name="subject" placeholder="Flooring estimate, question, etc." class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-brand-navy" />
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Message *</label>
              <textarea id="message" name="message" required rows="5" placeholder="Tell us how we can help..." class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-brand-navy"></textarea>
            </div>
            <button type="submit" class="btn-primary w-full justify-center">Send Message</button>
          </form>
        </div>

        <!-- Info -->
        <div class="space-y-6">
          <div class="bg-white rounded-2xl p-8 shadow-sm">
            <h3 class="font-heading font-bold text-brand-navy text-xl mb-5">Our Contact Information</h3>
            <div class="space-y-4 text-gray-700">
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-brand-gold mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <div>
                  <div class="font-semibold">Showroom Address</div>
                  <a href={company.googleMapsUrl} target="_blank" class="hover:text-brand-navy">{company.address.full}</a>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-brand-gold flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                <div>
                  <div class="font-semibold">Phone</div>
                  <a href={company.cta.phone} class="hover:text-brand-navy">{company.phone}</a>
                </div>
              </div>
            </div>

            <div class="mt-6 pt-6 border-t border-gray-100">
              <div class="font-semibold text-brand-navy mb-3">Showroom Hours</div>
              <div class="space-y-1 text-sm text-gray-600">
                <div class="flex justify-between"><span>Monday – Friday</span><span>9:00 AM – 5:30 PM</span></div>
                <div class="flex justify-between"><span>Saturday</span><span>10:00 AM – 4:00 PM</span></div>
                <div class="flex justify-between"><span>Sunday</span><span class="text-red-500">Closed</span></div>
              </div>
            </div>
          </div>

          <GoogleMap embedUrl={company.mapEmbedUrl} title="All About Floors NW showroom in Vancouver, WA" height="280px" />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
