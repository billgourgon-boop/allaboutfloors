---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import CTABanner from '@components/CTABanner.astro';
import FAQ from '@components/FAQ.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import ReviewsSection from '@components/ReviewsSection.astro';
import { installationServices } from '@data/services';
import { company } from '@data/company';

const svc = installationServices.find(s => s.slug === 'floor-repair')!;

const faq = [
  { q: 'What types of floor damage can you repair?', a: 'We repair squeaky boards, water-damaged sections, cracked or chipped tile, loose LVP planks, damaged laminate sections, pet damage to carpet and hardwood, and more.' },
  { q: 'Can you match existing hardwood for repairs?', a: 'In most cases, yes. We source matching boards and stain to blend repairs seamlessly with existing floors. Minor color variation may occur with aged hardwood.' },
  { q: 'Do you handle insurance claims for floor damage?', a: 'Yes, we work with insurance companies and can provide detailed repair documentation to support your claim.' },
  { q: 'How long do floor repairs take?', a: 'Simple repairs like replacing a few planks or squeaky board fixes are typically completed in a single visit. Larger water-damage repairs may take 2–3 days.' },
  { q: 'Is floor repair always less expensive than replacement?', a: 'For isolated damage, yes, repair is almost always more cost-effective. However, if damage is extensive (more than 30–40% of the floor), replacement may be recommended.' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Floor Repair in Vancouver, WA',
  description: svc.description,
  provider: {
    '@type': 'LocalBusiness',
    name: company.name,
    telephone: company.phoneDashes,
    address: {
      '@type': 'PostalAddress',
      streetAddress: company.address.street,
      addressLocality: company.address.city,
      addressRegion: company.address.state,
      postalCode: company.address.zip,
      addressCountry: 'US',
    },
  },
  url: 'https://www.allaboutfloorsnw.com/floor-repair/',
};
---

<BaseLayout
  title="Floor Repair in Vancouver, WA | All About Floors NW"
  description="Fast, professional floor repair in Vancouver, WA. Squeaky boards, water damage, cracked tile, loose planks, All About Floors NW fixes all flooring issues. Call (360) 525-2962."
  schema={schema}
>
  <Hero
    heading="Floor Repair in Vancouver, WA"
    subheading="Squeaky boards, water damage, cracked tile, or loose planks, our repair specialists fix all types of flooring damage quickly and affordably in Clark County and the Portland metro."
    image={svc.heroImage}
    imageAlt={svc.heroImageAlt}
    compact={true}
    badge="Fast Turnaround"
  />

  <Breadcrumb items={[{ label: 'Services', href: '/services/' }, { label: 'Floor Repair' }]} />

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="section-heading">Common Floor Repairs We Handle</h2>
        <p class="section-subheading mx-auto text-center">Don't let a small floor problem become a big one. All About Floors NW provides fast, reliable repairs for all flooring types.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: 'Squeaky & Loose Boards', desc: 'We locate and secure squeaky hardwood and laminate boards from above or below, no need to rip out flooring.' },
          { title: 'Water Damage Repair', desc: 'We remove and replace water-damaged flooring sections, address the moisture source, and restore your floors.' },
          { title: 'Cracked or Loose Tile', desc: 'Individual tile replacement with grout color matching. We carefully remove damaged tiles without disturbing adjacent areas.' },
          { title: 'LVP & Laminate Plank Replacement', desc: 'Individual planks can be removed and replaced in floating floor installations. Minimal disruption, perfect results.' },
          { title: 'Carpet Stretching & Re-Seaming', desc: 'We stretch loose, wrinkled carpet and repair seams that have separated or become visible.' },
          { title: 'Subfloor Repair', desc: 'Soft spots, squeaks, and uneven subfloors are addressed before any new flooring goes down.' },
        ].map(item => (
          <div class="bg-brand-light rounded-2xl p-6">
            <h3 class="font-heading font-semibold text-brand-navy text-lg mb-2">{item.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <FAQ items={faq} title="Floor Repair FAQ" />
  <ReviewsSection max={3} />
  <CTABanner heading="Floor Problem? Let's Fix It Fast." subtext="Contact All About Floors NW for a quick assessment. We'll diagnose the issue and recommend the most cost-effective repair solution." />
</BaseLayout>
