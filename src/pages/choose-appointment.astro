---
import BaseLayout from '@layouts/BaseLayout.astro';
import { company } from '@data/company';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Choose Your Appointment Type',
  url: 'https://www.allaboutfloorsnw.com/choose-appointment/',
  description: 'Pick how you want to meet with All About Floors NW — in your home or at our Vancouver, WA showroom.',
};
---

<BaseLayout
  title="Pick Your Appointment Type | All About Floors NW"
  description="Pick your appointment type — in your home or at our Vancouver, WA showroom."
  schema={schema}
  bare={true}
  noIndex={true}
>
  <!-- Meta Pixel Code (in <head>) — fire Lead on arrival -->
  <Fragment slot="head">
    <script is:inline>
      !function(f,b,e,v,n,t,s)
      {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)}(window, document,'script',
      'https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', '1975197519985839');
      fbq('track', 'PageView');
      fbq('track', 'Lead');
    </script>
    <noscript><img height="1" width="1" style="display:none"
      src="https://www.facebook.com/tr?id=1975197519985839&ev=Lead&noscript=1"
    /></noscript>
  </Fragment>

  <!-- Brand bar -->
  <div class="bg-brand-navy py-4 border-b border-white/5">
    <div class="max-w-7xl mx-auto px-4 flex items-center justify-center">
      <img
        src="/images/all-about-floors-nw-logo.webp"
        alt="All About Floors NW"
        class="h-10 w-auto max-w-[200px] object-contain"
        width="200"
        height="40"
        loading="eager"
      />
    </div>
  </div>

  <!-- Choice screen -->
  <section class="bg-white min-h-[80vh] flex items-center">
    <div class="max-w-3xl mx-auto px-4 py-16 md:py-24 text-center w-full">
      <div class="mx-auto w-14 h-14 rounded-full bg-green-100 flex items-center justify-center mb-6">
        <svg class="w-8 h-8 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
        </svg>
      </div>

      <h1 class="font-heading font-bold text-3xl md:text-5xl text-brand-navy leading-tight mb-4">
        Got it — last step.
      </h1>
      <p class="text-gray-600 text-lg md:text-xl leading-relaxed max-w-xl mx-auto mb-10">
        How would you like to meet? Pick in-home or in our Vancouver, WA showroom — both are 100% free, no pressure, no obligation.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-2xl mx-auto">
        <a
          href="/book-in-home/"
          class="group flex flex-col items-center justify-center gap-2 bg-black hover:bg-brand-gold text-white font-heading font-semibold text-lg md:text-xl px-6 py-7 rounded-2xl shadow-lg transition-all duration-200"
        >
          <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
          </svg>
          <span>In-Home Estimate</span>
          <span class="text-xs md:text-sm font-normal text-white/80 group-hover:text-white">We come to you with samples</span>
        </a>

        <a
          href="/book-in-store/"
          class="group flex flex-col items-center justify-center gap-2 bg-black hover:bg-brand-gold text-white font-heading font-semibold text-lg md:text-xl px-6 py-7 rounded-2xl shadow-lg transition-all duration-200"
        >
          <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 7h14l-1 12a2 2 0 01-2 2H8a2 2 0 01-2-2L5 7z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 7V5a3 3 0 016 0v2"/>
          </svg>
          <span>Showroom Appointment</span>
          <span class="text-xs md:text-sm font-normal text-white/80 group-hover:text-white">Visit us in Vancouver, WA</span>
        </a>
      </div>

      <p class="text-gray-500 text-sm mt-10">
        Prefer to talk? Call <a href={company.cta.phone} class="text-brand-navy font-semibold hover:underline">{company.phone}</a> or text us 24/7.
      </p>
    </div>
  </section>
</BaseLayout>
