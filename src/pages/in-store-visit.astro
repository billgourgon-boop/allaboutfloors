---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import GoogleMap from '@components/GoogleMap.astro';
import { company } from '@data/company';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'In-Store Showroom Visits & Consultations',
  url: 'https://www.allaboutfloorsnw.com/in-store-visit/',
  description: 'Visit the All About Floors NW showroom in Vancouver, WA for a hands-on flooring consultation. Touch real samples, compare colors in person, and walk out with a plan.',
};

const galleryImages = [
  {
    src: '/images/all-about-floors-nw-showroom-interior-vancouver-wa.webp',
    alt: 'All About Floors NW showroom interior with full sample displays in Vancouver, WA',
  },
  {
    src: '/images/CollageOfHardwoodLVPTileAndCarpet.png',
    alt: 'Showroom display of hardwood, LVP, tile and carpet samples side by side',
  },
  {
    src: '/images/CarpetSelection.webp',
    alt: 'Wide selection of carpet samples to compare colors and textures in person',
  },
  {
    src: '/images/LamaniateSelect.jpg',
    alt: 'Laminate flooring samples laid out for in-store comparison',
  },
  {
    src: '/images/VinylSlect.jpg',
    alt: 'Vinyl plank and tile samples available to view in the showroom',
  },
  {
    src: '/images/MarbelTileBathroom.png',
    alt: 'Tile sample displays from Dal Tile, Marazzi and Florida Tile',
  },
];

const steps = [
  {
    n: '1',
    title: 'Book your time',
    desc: 'Pick a slot that works for you on the showroom calendar — same-week appointments are usually available.',
  },
  {
    n: '2',
    title: 'Sit down with a designer',
    desc: 'A flooring expert walks you through products that fit your home, your style, and your budget. No pressure, no upselling.',
  },
  {
    n: '3',
    title: 'Take samples home',
    desc: 'See colors and textures in your own lighting. We\'ll have your itemized written quote ready when you\'re ready to move forward.',
  },
];

const reasons = [
  {
    title: 'Hundreds of samples in one place',
    desc: 'Mohawk, Shaw, Stanton, Hallmark, DuChateau, Quick Step, Anderson Tuftex, Dal Tile, Marazzi and more — all under one roof, all stocked locally.',
  },
  {
    title: 'Side-by-side color matching',
    desc: 'Bring a paint chip, a cabinet door, or a cushion. Hold real flooring next to it on a designer\'s table — you\'ll know in seconds what works.',
  },
  {
    title: 'Talk to a real installer',
    desc: 'Our crew is in-house, not subcontracted. The person who answers your install questions is the person whose team will be in your home.',
  },
  {
    title: 'Walk out with a plan',
    desc: 'Most visits end with a written quote, a finalized product pick, and a tentative install week — all in about an hour.',
  },
];
---

<BaseLayout
  title="Visit Our Vancouver, WA Flooring Showroom | All About Floors NW"
  description="Book an in-store consultation at the All About Floors NW showroom in Vancouver, WA. Touch real samples, compare colors in person, and leave with a plan. Call (360) 525-2962."
  schema={schema}
>
  <!-- Hero -->
  <section class="bg-brand-navy text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 20% 30%, #C8A55B 0%, transparent 50%), radial-gradient(circle at 80% 70%, #C8A55B 0%, transparent 50%);"></div>
    <div class="max-w-7xl mx-auto px-4 py-14 md:py-20 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center relative z-10">
      <div>
        <span class="inline-block bg-brand-gold/20 border border-brand-gold/40 text-brand-gold-light text-xs md:text-sm font-semibold uppercase tracking-widest px-4 py-1.5 rounded-full mb-6">
          Vancouver, WA Showroom
        </span>
        <h1 class="font-heading font-bold text-4xl md:text-5xl lg:text-6xl leading-tight mb-5">
          Visit Our Showroom for a <span class="text-brand-gold">Hands-On Consultation.</span>
        </h1>
        <p class="text-gray-200 text-lg md:text-xl leading-relaxed mb-7 max-w-xl">
          Hundreds of carpet, hardwood, LVP, laminate and tile samples — all in one place. Sit down with a designer, see colors in real light, and walk out with a written plan for your project.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/book-in-store/" class="btn-primary">Book Showroom Appointment</a>
          <a href={company.cta.phone} class="btn-outline-white">Call {company.phone}</a>
        </div>
        <div class="mt-8 pt-6 border-t border-white/10 grid grid-cols-2 gap-6 text-sm">
          <div>
            <div class="text-brand-gold font-semibold mb-1">Showroom address</div>
            <a href={company.googleMapsUrl} target="_blank" rel="noopener" class="text-gray-200 hover:text-white">{company.address.full}</a>
          </div>
          <div>
            <div class="text-brand-gold font-semibold mb-1">Showroom hours</div>
            <div class="text-gray-200">{company.hoursDisplay}</div>
          </div>
        </div>
      </div>
      <div class="rounded-2xl overflow-hidden shadow-2xl">
        <img
          src="/images/all-about-floors-nw-showroom-interior-vancouver-wa.webp"
          alt="All About Floors NW showroom in Vancouver, WA with carpet, hardwood, vinyl and tile sample displays"
          class="w-full h-full object-cover aspect-[4/3]"
          width="800"
          height="600"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <Breadcrumb items={[{ label: 'In-Store Visits' }]} />

  <!-- What to expect -->
  <section class="py-16 bg-brand-light">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
        <span class="badge-gold mb-3">How It Works</span>
        <h2 class="section-heading mt-2">What to Expect at Your Showroom Visit</h2>
        <p class="text-gray-600 mt-4 max-w-2xl mx-auto">A relaxed one-hour appointment with a designer who actually knows the products. Bring whatever inspiration you have — paint chips, photos, even cabinet samples.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {steps.map(step => (
          <div class="bg-white rounded-2xl p-7 shadow-sm relative">
            <div class="absolute -top-5 left-7 w-10 h-10 rounded-full bg-brand-gold text-white font-heading font-bold flex items-center justify-center text-lg shadow-md">
              {step.n}
            </div>
            <h3 class="font-heading font-semibold text-brand-navy text-xl mb-2 mt-3">{step.title}</h3>
            <p class="text-gray-600 leading-relaxed text-sm">{step.desc}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/book-in-store/" class="btn-primary btn-pulse">Book Showroom Appointment</a>
      </div>
    </div>
  </section>

  <!-- Sample gallery -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <span class="badge-gold mb-3">Inside the Showroom</span>
        <h2 class="section-heading mt-2">Samples You Can Actually Touch</h2>
        <p class="text-gray-600 mt-4 max-w-2xl mx-auto">Photos and online swatches only get you so far. Texture, sheen, plank width, fiber height — those are the details that matter, and you can only see them in person.</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-6">
        {galleryImages.map(img => (
          <div class="rounded-xl overflow-hidden shadow-sm group">
            <img
              src={img.src}
              alt={img.alt}
              class="w-full h-full object-cover aspect-[4/3] group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
              width="600"
              height="450"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why visit -->
  <section class="py-16 bg-brand-light">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <span class="badge-gold mb-3">Why Visit Us</span>
        <h2 class="section-heading mt-2">Why a Showroom Visit Beats Browsing Online</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {reasons.map(r => (
          <div class="bg-white rounded-2xl p-7 shadow-sm flex gap-4">
            <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-brand-gold/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-brand-gold" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            </div>
            <div>
              <h3 class="font-heading font-semibold text-brand-navy text-lg mb-1.5">{r.title}</h3>
              <p class="text-gray-600 leading-relaxed text-sm">{r.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA + map -->
  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4 grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
      <div>
        <span class="badge-gold mb-3">Plan Your Visit</span>
        <h2 class="section-heading mt-2 mb-4">Stop In and See for Yourself</h2>
        <p class="text-gray-700 leading-relaxed mb-6">
          We're open Monday through Saturday at our Vancouver, WA showroom. Booking ahead means a designer is set aside just for you — but walk-ins are always welcome too.
        </p>
        <div class="space-y-3">
          <a href="/book-in-store/" class="btn-primary w-full sm:w-auto sm:inline-flex">
            Book Showroom Appointment
          </a>
          <div class="block">
            <a href={company.cta.phone} class="btn-secondary w-full sm:w-auto sm:inline-flex">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              Call {company.phone}
            </a>
          </div>
        </div>
        <div class="mt-8 pt-6 border-t border-gray-200 space-y-2 text-sm text-gray-700">
          <div class="flex items-start gap-2">
            <svg class="w-4 h-4 text-brand-gold flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
            <span><strong class="text-brand-navy">Showroom:</strong> {company.address.full}</span>
          </div>
          <div class="flex items-start gap-2">
            <svg class="w-4 h-4 text-brand-gold flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span><strong class="text-brand-navy">Hours:</strong> {company.hoursDisplay}</span>
          </div>
        </div>
      </div>
      <GoogleMap
        embedUrl={company.mapEmbedUrl}
        title="All About Floors NW showroom location in Vancouver, WA"
        height="380px"
      />
    </div>
  </section>
</BaseLayout>
