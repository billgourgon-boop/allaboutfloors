---
import BaseLayout from '@layouts/BaseLayout.astro';
import { company } from '@data/company';
---

<BaseLayout
  title="Privacy Policy | All About Floors NW"
  description="Privacy policy for All About Floors NW in Vancouver, WA."
  noIndex={true}
>
  <div class="max-w-3xl mx-auto px-4 py-20 prose prose-gray">
    <h1>Privacy Policy</h1>
    <p><strong>Effective Date:</strong> January 1, 2024</p>
    <p>{company.name} respects your privacy. This policy explains how we collect, use, and protect your information when you visit our website or contact us for flooring services.</p>

    <h2>Information We Collect</h2>
    <p>We may collect your name, phone number, and project address when you fill out our estimate or contact forms. We do not sell or share this information with third parties.</p>

    <h2>How We Use Your Information</h2>
    <p>We use your information solely to respond to your inquiries, schedule estimates, and follow up on your flooring projects.</p>

    <h2>Contact Us</h2>
    <p>If you have questions about this policy, call <a href={company.cta.phone}>{company.phone}</a>.</p>
  </div>
</BaseLayout>
